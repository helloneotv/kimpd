# Neon Console → Connect → 연결 문자열 복사
# sslmode=require 포함 권장
# 풀러 URL은 호스트 뒤에 :5432가 붙는 경우가 많습니다. Neon Connect에서 복사한 그대로 쓰면 됩니다.
# 앱 코드가 풀러 호스트일 때 connect_timeout / pgbouncer / connection_limit 등을 자동 보강합니다.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech:5432/neondb?sslmode=require"

# Data API v3 등 서버에서만 사용 (클라이언트에 노출 금지)
YOUTUBE_API_KEY=""
