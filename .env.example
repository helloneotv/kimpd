# Neon Console → Connect → 연결 문자열 복사
# sslmode=require 포함 권장
# Neon Connect에서 복사한 연결 문자열을 그대로 넣습니다.
# 코드: channel_binding 파라미터 제거 + 없을 때만 connect_timeout=15 추가 (Neon/Prisma 권장).
NEW_DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech:5432/neondb?sslmode=require"

# Data API v3 등 서버에서만 사용 (클라이언트에 노출 금지)
YOUTUBE_API_KEY=""
